{
  "$schema": "Investor Profile - Private Equity (Value-Add / Opportunistic Fund)",
  "investorType": "private-equity",
  "teamComposition": {
    "tier1Override": {
      "buyerAgent": "buyer-private-equity",
      "additionalAgents": ["value-add-operator"],
      "removeAgents": []
    },
    "tier2Bias": {
      "alwaysTrigger": ["perspective-construction"],
      "neverTrigger": []
    }
  },
  "primaryCriteria": {
    "dscr": {
      "pass": 1.15,
      "conditional": 1.0,
      "fail": 0.85,
      "description": "Debt Service Coverage Ratio"
    },
    "ltv": {
      "maxPass": 0.75,
      "maxConditional": 0.78,
      "fail": 0.80,
      "description": "Loan to Value Ratio"
    },
    "cashOnCash": {
      "pass": 0.08,
      "conditional": 0.05,
      "fail": 0.02,
      "description": "Annual cash flow / equity invested"
    },
    "debtYield": {
      "pass": 0.08,
      "conditional": 0.07,
      "fail": 0.06,
      "description": "NOI / loan amount"
    }
  },
  "dealbreakers": [
    "No clear value-add thesis (NOI growth <25%)",
    "Entitlement risk without clear path",
    "Environmental remediation of unknown scope",
    "Operating partners without track record",
    "DSCR <0.80 without turnaround plan"
  ],
  "reportingVariant": "private-equity",
  "allowedStrategies": ["value-add", "opportunistic"]
}
