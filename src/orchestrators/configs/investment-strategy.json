{
  "orchestratorId": "investment-strategy",
  "version": "2.0.0",
  "entityType": "strategy",
  "description": "Five-phase investment strategy pipeline covering market selection, strategy definition, target identification, pipeline management, and semi-annual strategy review. Coordinates 10 specialist agents plus 2 existing senior agents (CIO, portfolio-strategist) across sequential phases with Phase 5 recurring semi-annually. Terminal verdicts: ACTIVE (strategy confirmed), PIVOT (specific parameter adjustments needed), PAUSE (halt deployment until conditions improve). Cross-chain handoffs: inbound from portfolio-management and research-intelligence; outbound to fund-management, acquisition, and development pipelines.",
  "model": "claude-opus-4-6[1m]",
  "terminalVerdicts": ["ACTIVE", "PIVOT", "PAUSE"],
  "phases": [
    {
      "phaseId": "market-selection",
      "name": "Market Selection",
      "weight": 0.25,
      "orchestratorFile": "orchestrators/investment-strategy-orchestrator.md",
      "agents": [
        {
          "agentId": "macro-analyst",
          "file": "agents/strategy/macro-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "target geography universe (default: top 50 US MSAs)",
            "investment strategy type from config or upstream",
            "capital profile (deployment size and timeline)",
            "research intelligence handoff (if available)"
          ],
          "outputs": [
            "MSA universe with filtering rationale",
            "employment growth scorecards by MSA",
            "demographic trend analysis by MSA",
            "GDP and economic output analysis by MSA",
            "affordability and cost analysis by MSA",
            "migration pattern analysis by MSA",
            "composite MSA ranking with tier assignment (1-5)",
            "market selection memo"
          ],
          "critical": true,
          "dependencies": [],
          "skillRefs": [
            "skills/market-memo-generator.md",
            "skills/supply-demand-forecast.md"
          ],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {
              "ruleId": "msa-universe-defined",
              "description": "MSA universe must contain at least 10 MSAs with population and employment data.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "composite-ranking-complete",
              "description": "Every MSA in the universe must have a composite score (0-100) and tier assignment (1-5).",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "tier-1-markets-identified",
              "description": "At least 3 Tier 1 MSAs must be identified with supporting data for all 6 scoring dimensions.",
              "actionOnFailure": "halt_phase"
            }
          ]
        },
        {
          "agentId": "submarket-screener",
          "file": "agents/strategy/submarket-screener.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "Tier 1 and Tier 2 MSAs from macro-analyst",
            "investment strategy type and property type focus",
            "capital profile (equity check range)",
            "research intelligence handoff (if available)"
          ],
          "outputs": [
            "submarket universe by MSA",
            "occupancy, rent, and absorption fundamentals by submarket",
            "supply pipeline risk assessment by submarket",
            "competitive set analysis by submarket",
            "Mueller cycle positioning by submarket",
            "composite submarket ranking with recommendations"
          ],
          "critical": true,
          "dependencies": [],
          "skillRefs": [
            "skills/submarket-truth-serum.md",
            "skills/market-cycle-positioner.md"
          ],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {
              "ruleId": "submarket-fundamentals-complete",
              "description": "Every evaluated submarket must have occupancy, rent, and absorption data.",
              "actionOnFailure": "flag_data_gap"
            },
            {
              "ruleId": "supply-pipeline-assessed",
              "description": "Supply pipeline risk must be assessed for all Tier 1 MSA submarkets with supply-as-%-of-stock calculated.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "cycle-positioning-complete",
              "description": "Mueller cycle position must be assigned to every ranked submarket.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "primary-targets-exist",
              "description": "Each Tier 1 MSA must have at least one PRIMARY TARGET submarket.",
              "actionOnFailure": "halt_phase"
            }
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "investmentStrategy.marketSelection",
        "passConditions": [
          {
            "conditionId": "tier-1-coverage",
            "description": "At least 3 Tier 1 MSAs identified with composite scores above 65.",
            "propagateIfFailed": true
          },
          {
            "conditionId": "submarket-targets-identified",
            "description": "At least 5 PRIMARY TARGET submarkets identified across Tier 1 MSAs.",
            "propagateIfFailed": true
          }
        ],
        "conditionalConditions": [
          {
            "conditionId": "data-freshness",
            "description": "Employment and GDP data no older than 12 months; Census data no older than 3 years.",
            "propagateIfFailed": false
          }
        ]
      }
    },
    {
      "phaseId": "strategy-definition",
      "name": "Strategy Definition",
      "weight": 0.25,
      "orchestratorFile": "orchestrators/investment-strategy-orchestrator.md",
      "agents": [
        {
          "agentId": "strategy-architect",
          "file": "agents/strategy/strategy-architect.md",
          "model": "claude-opus-4-6[1m]",
          "inputs": [
            "MSA rankings and tier assignments from macro-analyst",
            "submarket scorecards from submarket-screener",
            "capital profile (total capital, timeline, mandates)",
            "investor mandates and constraints",
            "cycle assessment from Phase 1",
            "benchmark data (NCREIF, ODCE, Preqin)"
          ],
          "outputs": [
            "risk-return profile selection (core/core-plus/value-add/opportunistic)",
            "target allocation matrix (property type x geography x risk tier x vintage)",
            "hold period parameters and exit strategy",
            "return targets with scenario analysis (bull/base/bear/stress)",
            "leverage policy",
            "strategy differentiation narrative"
          ],
          "critical": true,
          "dependencies": ["macro-analyst", "submarket-screener"],
          "skillRefs": [
            "skills/portfolio-allocator.md"
          ],
          "maxTimeoutMinutes": 50,
          "validationRules": [
            {
              "ruleId": "allocation-sums-valid",
              "description": "Property type, geographic, risk tier, and vintage allocations must each sum to 100% (tolerance 0.1%).",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "return-targets-consistent",
              "description": "IRR, equity multiple, and hold period must be mathematically consistent.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "mandate-compliance-verified",
              "description": "Every allocation parameter must satisfy investor mandate constraints.",
              "actionOnFailure": "halt_phase"
            },
            {
              "ruleId": "scenario-analysis-complete",
              "description": "All four scenarios (bull/base/bear/stress) must have IRR and EM calculations.",
              "actionOnFailure": "retry_agent"
            }
          ]
        },
        {
          "agentId": "thesis-writer",
          "file": "agents/strategy/thesis-writer.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "complete strategy framework from strategy-architect",
            "MSA rankings from macro-analyst",
            "submarket scorecards from submarket-screener",
            "capital profile and investor context",
            "cycle assessment from Phase 1",
            "benchmark data for positioning"
          ],
          "outputs": [
            "investment thesis document (executive summary, market rationale, strategy framework, competitive advantages, risk factors, financial exhibits)",
            "thesis validation checklist results"
          ],
          "critical": true,
          "dependencies": ["strategy-architect"],
          "skillRefs": [
            "skills/memo-investment-drafter.md"
          ],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {
              "ruleId": "quantitative-claims-sourced",
              "description": "Every quantitative claim in the thesis must have a cited data source.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "risk-factors-minimum",
              "description": "At least 15 risk factors must be identified with mitigation strategies.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "internal-consistency",
              "description": "All figures in thesis must match strategy-architect output exactly.",
              "actionOnFailure": "halt_phase"
            }
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "investmentStrategy.strategyDefinition",
        "passConditions": [
          {
            "conditionId": "strategy-selected",
            "description": "Primary strategy type selected with decision matrix scoring.",
            "propagateIfFailed": true
          },
          {
            "conditionId": "allocation-complete",
            "description": "All four allocation dimensions defined with targets and ranges.",
            "propagateIfFailed": true
          },
          {
            "conditionId": "thesis-document-produced",
            "description": "Investment thesis document produced with all required sections.",
            "propagateIfFailed": true
          }
        ]
      }
    },
    {
      "phaseId": "target-identification",
      "name": "Target Identification",
      "weight": 0.20,
      "orchestratorFile": "orchestrators/investment-strategy-orchestrator.md",
      "agents": [
        {
          "agentId": "deal-sourcing-engine",
          "file": "agents/strategy/deal-sourcing-engine.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "strategy framework from strategy-architect",
            "submarket rankings from submarket-screener",
            "MSA rankings from macro-analyst",
            "capital profile (equity check range, timeline)"
          ],
          "outputs": [
            "target acquisition profile (TAP)",
            "multi-channel sourcing strategy",
            "lead scoring model (0-100)",
            "CRM pipeline schema",
            "outreach execution plan",
            "initial lead pipeline with scores"
          ],
          "critical": true,
          "dependencies": ["strategy-architect", "submarket-screener"],
          "skillRefs": [
            "skills/sourcing-outreach-system.md",
            "skills/deal-quick-screen.md"
          ],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {
              "ruleId": "tap-strategy-aligned",
              "description": "Target acquisition profile must be consistent with strategy-architect allocation targets and return criteria.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "submarket-coverage",
              "description": "At least 80% of primary target submarkets must have identified leads.",
              "actionOnFailure": "flag_data_gap"
            },
            {
              "ruleId": "channel-diversification",
              "description": "No single sourcing channel may exceed 60% of pipeline.",
              "actionOnFailure": "retry_agent"
            }
          ]
        },
        {
          "agentId": "broker-relationship-manager",
          "file": "agents/strategy/broker-relationship-manager.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "broker network data from deal-sourcing-engine",
            "deal pipeline with source attribution",
            "Tier 1/2 MSAs from macro-analyst",
            "target acquisition profile from deal-sourcing-engine"
          ],
          "outputs": [
            "broker universe mapping with coverage matrix",
            "relationship scoring (0-100) per broker",
            "deal flow attribution system",
            "engagement strategy by broker category",
            "off-market access development plan"
          ],
          "critical": false,
          "dependencies": ["deal-sourcing-engine"],
          "skillRefs": [
            "skills/sourcing-outreach-system.md"
          ],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {
              "ruleId": "broker-coverage-threshold",
              "description": "Overall broker coverage must exceed 90% of target MSAs.",
              "actionOnFailure": "flag_data_gap"
            },
            {
              "ruleId": "attribution-integrity",
              "description": "Every pipeline deal must have a primary source attribution.",
              "actionOnFailure": "retry_agent"
            }
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "investmentStrategy.targetIdentification",
        "passConditions": [
          {
            "conditionId": "tap-defined",
            "description": "Target acquisition profile defined with property, financial, and geographic criteria.",
            "propagateIfFailed": true
          },
          {
            "conditionId": "pipeline-seeded",
            "description": "Initial pipeline contains leads across target MSAs and property types.",
            "propagateIfFailed": true
          }
        ]
      }
    },
    {
      "phaseId": "pipeline-management",
      "name": "Pipeline Management",
      "weight": 0.15,
      "orchestratorFile": "orchestrators/investment-strategy-orchestrator.md",
      "agents": [
        {
          "agentId": "pipeline-analyst",
          "file": "agents/strategy/pipeline-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "deal pipeline with stage history from deal-sourcing-engine CRM",
            "screening results from quick-screen-operator",
            "deployment targets from strategy-architect",
            "allocation targets from strategy-architect"
          ],
          "outputs": [
            "funnel analysis (counts, values, conversions per stage)",
            "conversion rate analysis by stage, property type, MSA, channel",
            "deal velocity analysis with stale deal identification",
            "pipeline value and deployment forecasting",
            "dead deal analysis with pattern identification",
            "pipeline health dashboard"
          ],
          "critical": true,
          "dependencies": ["deal-sourcing-engine", "quick-screen-operator"],
          "skillRefs": [
            "skills/deal-quick-screen.md"
          ],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {
              "ruleId": "funnel-math-consistent",
              "description": "Deal counts at each stage plus dead plus advanced must equal count entering stage.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "coverage-ratio-calculated",
              "description": "Pipeline coverage ratio must use correct stage probability weights.",
              "actionOnFailure": "retry_agent"
            }
          ]
        },
        {
          "agentId": "quick-screen-operator",
          "file": "agents/strategy/quick-screen-operator.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "deal submissions (OMs, flyers, broker packages)",
            "target acquisition profile from deal-sourcing-engine",
            "return targets from strategy-architect",
            "submarket data from submarket-screener",
            "thresholds from config/thresholds.json"
          ],
          "outputs": [
            "KEEP/KILL/CONDITIONAL verdict per deal",
            "back-of-napkin return estimates (cap rate, unlevered IRR, levered IRR, CoC, EM)",
            "red flag identification (financial, market, physical, deal structure)",
            "key assumptions documentation",
            "preliminary diligence checklist (for KEEP/CONDITIONAL deals)"
          ],
          "critical": true,
          "dependencies": ["deal-sourcing-engine"],
          "skillRefs": [
            "skills/deal-quick-screen.md",
            "skills/om-reverse-pricing.md"
          ],
          "maxTimeoutMinutes": 30,
          "validationRules": [
            {
              "ruleId": "verdict-consistency",
              "description": "Verdict must be consistent with composite score and red flag assessment.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "return-math-valid",
              "description": "Cap rate, NOI, and price must be internally consistent.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "assumptions-documented",
              "description": "Every KEEP/CONDITIONAL verdict must have at least 3 documented key assumptions.",
              "actionOnFailure": "retry_agent"
            }
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "investmentStrategy.pipelineManagement",
        "passConditions": [
          {
            "conditionId": "pipeline-health-adequate",
            "description": "Pipeline health status is HEALTHY or ADEQUATE (not STRAINED or CRITICAL).",
            "propagateIfFailed": false
          },
          {
            "conditionId": "screening-operational",
            "description": "Quick screen operator has processed at least one deal with valid KEEP/KILL verdict.",
            "propagateIfFailed": true
          }
        ]
      }
    },
    {
      "phaseId": "strategy-review",
      "name": "Strategy Review",
      "weight": 0.15,
      "recurring": true,
      "recurrenceSchedule": "semi-annual",
      "orchestratorFile": "orchestrators/investment-strategy-orchestrator.md",
      "agents": [
        {
          "agentId": "strategy-reviewer",
          "file": "agents/strategy/strategy-reviewer.md",
          "model": "claude-opus-4-6[1m]",
          "inputs": [
            "original thesis from thesis-writer",
            "strategy framework from strategy-architect",
            "pipeline metrics from pipeline-analyst",
            "allocation drift from allocation-drift-analyst",
            "current market data (fresh research required)",
            "portfolio performance for deployed assets"
          ],
          "outputs": [
            "thesis assumption validation (valid/partial/invalid per assumption)",
            "Mueller cycle reassessment",
            "portfolio fit reassessment (deployment, allocations, returns)",
            "scenario re-run with updated assumptions",
            "strategy pivot analysis (triggers, options, recommendation)",
            "ACTIVE/PIVOT/PAUSE verdict"
          ],
          "critical": true,
          "dependencies": ["allocation-drift-analyst"],
          "skillRefs": [
            "skills/market-cycle-positioner.md",
            "skills/supply-demand-forecast.md"
          ],
          "maxTimeoutMinutes": 50,
          "validationRules": [
            {
              "ruleId": "assumptions-fully-reviewed",
              "description": "Every original thesis assumption must be re-evaluated with current data.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "verdict-follows-rules",
              "description": "ACTIVE/PIVOT/PAUSE verdict must follow defined trigger and threshold rules.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "pivot-specificity",
              "description": "PIVOT verdict must include specific parameter changes and implementation timeline.",
              "actionOnFailure": "retry_agent"
            }
          ]
        },
        {
          "agentId": "allocation-drift-analyst",
          "file": "agents/strategy/allocation-drift-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": [
            "target allocations from strategy-architect",
            "current portfolio composition (deployed assets)",
            "active pipeline deals by property type, MSA, risk tier",
            "drift thresholds from config/thresholds.json",
            "fund parameters (total capital, deployed, remaining)"
          ],
          "outputs": [
            "current vs target allocations across all dimensions",
            "vintage year analysis with rolling window tests",
            "forward-looking drift projection incorporating pipeline",
            "composite drift score and classification",
            "rebalancing trigger identification and status",
            "rebalancing recommendations (if triggers activated)"
          ],
          "critical": true,
          "dependencies": [],
          "skillRefs": [
            "skills/portfolio-allocator.md"
          ],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {
              "ruleId": "allocation-sums-valid",
              "description": "Actual allocations must sum to 100% per dimension (tolerance 0.1%).",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "drift-calculation-correct",
              "description": "Drift must equal |target - actual| for each category. Composite must use defined weights.",
              "actionOnFailure": "retry_agent"
            },
            {
              "ruleId": "triggers-evaluated",
              "description": "All 6 rebalancing triggers must be evaluated against defined thresholds.",
              "actionOnFailure": "retry_agent"
            }
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "investmentStrategy.strategyReview",
        "passConditions": [
          {
            "conditionId": "thesis-validity-above-threshold",
            "description": "Thesis assumptions validity score must be above 50% for any verdict other than PAUSE.",
            "propagateIfFailed": true
          },
          {
            "conditionId": "verdict-rendered",
            "description": "ACTIVE/PIVOT/PAUSE verdict must be rendered with confidence score.",
            "propagateIfFailed": true
          }
        ]
      }
    }
  ],
  "crossChainHandoffs": {
    "inbound": [
      {
        "sourceOrchestrator": "portfolio-management",
        "trigger": "allocation drift exceeds threshold OR rebalancing recommendation generated",
        "dataContract": [
          "current portfolio allocations",
          "drift measurements",
          "rebalancing triggers"
        ]
      },
      {
        "sourceOrchestrator": "research-intelligence",
        "trigger": "research verdict == INVEST or MONITOR",
        "dataContract": [
          "researchMemo",
          "targetAcquisitionProfiles",
          "submarketScorecard"
        ]
      }
    ],
    "outbound": [
      {
        "targetOrchestrator": "fund-management",
        "trigger": "strategy verdict == ACTIVE or PIVOT",
        "dataContract": [
          "investmentStrategy (required)",
          "allocationTargets (required)",
          "returnTargets (required)",
          "leveragePolicy (required)",
          "concentrationLimits (required)"
        ]
      },
      {
        "targetOrchestrator": "acquisition",
        "trigger": "strategy verdict == ACTIVE AND pipeline has KEEP deals",
        "dataContract": [
          "targetAcquisitionProfile (required)",
          "returnTargets (required)",
          "concentrationLimits (required)",
          "keepDeals (required)"
        ]
      },
      {
        "targetOrchestrator": "development",
        "trigger": "risk tier allocation includes development AND pipeline has development deals",
        "dataContract": [
          "developmentAllocation (required)",
          "targetMarkets (required)",
          "returnTargets (required)"
        ]
      }
    ]
  },
  "executionConfig": {
    "maxConcurrentAgents": 4,
    "phase1Parallelism": ["macro-analyst", "submarket-screener"],
    "phase2Sequence": ["strategy-architect", "thesis-writer"],
    "phase3Sequence": ["deal-sourcing-engine", "broker-relationship-manager"],
    "phase4Parallelism": ["pipeline-analyst", "quick-screen-operator"],
    "phase5Sequence": ["allocation-drift-analyst", "strategy-reviewer"],
    "globalTimeout_minutes": 480,
    "retryPolicy": {
      "maxRetries": 2,
      "backoffMultiplier": 1.5,
      "initialBackoff_seconds": 30
    }
  }
}
