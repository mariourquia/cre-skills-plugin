{
  "orchestratorId": "development",
  "version": "2.0.0",
  "entityType": "project",
  "description": "Seven-phase ground-up development lifecycle pipeline covering land acquisition & entitlement, design & pre-construction, construction financing, construction execution, lease-up/stabilization, permanent financing conversion, and handoff to hold period. Coordinates 18 specialist agents across sequential phases to produce a terminal verdict of STABILIZED, DELAYED, or DISTRESSED. Manages construction draw schedules, GMP tracking, and stabilization curve monitoring throughout. Terminal deliverable is either a stabilized property handed off to hold-period-monitor (HOLD) or disposition-strategy (SELL).",
  "model": "claude-opus-4-6[1m]",
  "phases": [
    {
      "phaseId": "land-acquisition-entitlement",
      "name": "Land Acquisition & Entitlement",
      "weight": 0.15,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "land-residual-analyst",
          "file": "agents/development/land-residual-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["config/deal.json", "zoning code", "market rent data", "construction cost data", "comparable land sales"],
          "outputs": ["residual land value (3 methods)", "HBU analysis", "site capacity matrix", "sensitivity analysis"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/land-residual-hbu-analyzer.md", "skills/entitlement-feasibility.md"],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {"ruleId": "min-two-programs", "description": "Residual must be calculated for at least two candidate use types.", "actionOnFailure": "retry_agent"},
            {"ruleId": "three-method-reconciliation", "description": "YOC, IRR, and EM residual methods must all be calculated.", "actionOnFailure": "retry_agent"},
            {"ruleId": "hbu-concluded", "description": "HBU program must be identified with supporting rationale.", "actionOnFailure": "halt_phase"}
          ]
        },
        {
          "agentId": "entitlement-risk-assessor",
          "file": "agents/development/entitlement-risk-assessor.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["land-residual-analyst output", "zoning code", "local planning regulations", "comparable approvals"],
          "outputs": ["zoning conformance analysis", "approval pathway", "NIMBY assessment", "entitlement timeline & cost", "feasibility verdict"],
          "critical": true,
          "dependencies": ["land-residual-analyst"],
          "skillRefs": ["skills/entitlement-feasibility.md", "skills/compliance-regulatory-response-kit.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "zoning-analyzed", "description": "Every dimensional standard must be evaluated for conformance.", "actionOnFailure": "retry_agent"},
            {"ruleId": "approval-pathway-mapped", "description": "All required approvals must be identified with timeline and cost.", "actionOnFailure": "retry_agent"},
            {"ruleId": "feasibility-verdict-issued", "description": "Feasibility verdict must be FEASIBLE, CONDITIONAL, or NOT_FEASIBLE.", "actionOnFailure": "halt_phase"}
          ]
        },
        {
          "agentId": "community-engagement-coordinator",
          "file": "agents/development/community-engagement-coordinator.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["entitlement-risk-assessor output", "community data", "political data"],
          "outputs": ["stakeholder map", "engagement strategy", "opposition response framework", "community benefits package"],
          "critical": false,
          "dependencies": ["entitlement-risk-assessor"],
          "skillRefs": ["skills/compliance-regulatory-response-kit.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "stakeholders-mapped", "description": "All Tier 1 stakeholders (adjacent owners) must be identified.", "actionOnFailure": "flag_data_gap"},
            {"ruleId": "opposition-prepared", "description": "Every NIMBY factor must have a prepared response.", "actionOnFailure": "flag_data_gap"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "land-price-within-residual", "description": "Contracted or target land price <= maximum supportable land cost from residual analysis.", "propagateIfFailed": true},
          {"conditionId": "hbu-achievable", "description": "HBU program achievable under current zoning or reasonable entitlement path.", "propagateIfFailed": true},
          {"conditionId": "entitlement-feasible", "description": "Entitlement verdict is FEASIBLE or CONDITIONAL with manageable conditions.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "no-viable-program", "description": "No candidate program produces a positive residual land value.", "propagateIfFailed": true},
          {"conditionId": "fatal-site-constraint", "description": "Fatal environmental or physical constraint cannot be remediated within budget.", "propagateIfFailed": true},
          {"conditionId": "entitlement-impossible", "description": "Required entitlements cannot be obtained within viable project timeline.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["noViableProgram", "fatalEnvironmentalConstraint", "landCostAboveResidual", "entitlementImpossible"]
      },
      "dataForDownstreamContract": {
        "hbuProgram": {"type": "object", "required": true, "description": "Optimal program with unit mix, FAR, and market rent assumptions."},
        "maxSupportableLandCost": {"type": "number", "required": true, "description": "Maximum land cost at target returns from residual analysis."},
        "entitlementPathway": {"type": "object", "required": true, "description": "Approval strategy, timeline, milestones, and risk score."},
        "entitlementCostBudget": {"type": "number", "required": true, "description": "Total entitlement cost including permits, fees, soft costs."},
        "siteCapacity": {"type": "object", "required": true, "description": "Buildable SF/units, parking, utility constraints."}
      }
    },
    {
      "phaseId": "design-pre-construction",
      "name": "Design & Pre-Construction",
      "weight": 0.15,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "proforma-builder",
          "file": "agents/development/proforma-builder.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["land-residual-analyst output", "entitlement-risk-assessor output", "market data", "construction cost data"],
          "outputs": ["development pro forma (monthly)", "TDC budget", "draw schedule", "return metrics", "go/no-go verdict"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/dev-proforma-engine.md"],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {"ruleId": "tdc-complete", "description": "All five TDC categories must be quantified.", "actionOnFailure": "halt_phase"},
            {"ruleId": "return-metrics-calculated", "description": "YOC, development spread, IRR, EM all computed.", "actionOnFailure": "retry_agent"},
            {"ruleId": "go-nogo-evaluated", "description": "Every return metric compared against fund threshold.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "design-team-evaluator",
          "file": "agents/development/design-team-evaluator.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "design team proposals", "reference projects"],
          "outputs": ["design team evaluation matrix", "selection recommendation", "contract terms", "design schedule"],
          "critical": true,
          "dependencies": ["proforma-builder"],
          "skillRefs": ["skills/construction-procurement-contracts-engine.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "min-candidates", "description": "At least two architect candidates evaluated.", "actionOnFailure": "flag_data_gap"},
            {"ruleId": "fee-benchmarked", "description": "Fees compared against budget and industry benchmarks.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "value-engineering-analyst",
          "file": "agents/development/value-engineering-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "design specifications"],
          "outputs": ["VE register", "savings quantification", "prioritized recommendations"],
          "critical": false,
          "dependencies": ["proforma-builder"],
          "skillRefs": ["skills/construction-budget-gc-analyzer.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "min-ve-items", "description": "At least 10 VE items evaluated across 4+ categories.", "actionOnFailure": "flag_data_gap"},
            {"ruleId": "savings-quantified", "description": "Every VE item must have a dollar savings estimate.", "actionOnFailure": "retry_agent"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "positive-development-spread", "description": "Yield on cost exceeds exit cap rate by minimum development spread.", "propagateIfFailed": true},
          {"conditionId": "irr-above-hurdle", "description": "Development IRR at base case meets fund hurdle rate.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "negative-development-spread", "description": "Yield on cost below exit cap rate -- development destroys value.", "propagateIfFailed": true},
          {"conditionId": "irr-far-below-hurdle", "description": "IRR more than 200bps below hurdle at base case.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["negativeDevelopmentSpread", "constructionCostOverrunKillsFeasibility"]
      },
      "dataForDownstreamContract": {
        "developmentProforma": {"type": "object", "required": true, "description": "Full pro forma with TDC, NOI, return metrics."},
        "totalProjectCost": {"type": "number", "required": true, "description": "All-in TDC for construction loan sizing."},
        "drawSchedule": {"type": "array", "required": true, "description": "Monthly draw schedule for construction financing."},
        "constructionTimeline": {"type": "object", "required": true, "description": "Construction start, completion, lease-up schedule."}
      }
    },
    {
      "phaseId": "construction-financing",
      "name": "Construction Financing",
      "weight": 0.10,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "construction-lender-analyst",
          "file": "agents/development/construction-lender-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "lender program sheets", "market rate data"],
          "outputs": ["construction loan sizing", "lender comparison", "draw alignment", "covenant framework", "conversion path"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/loan-sizing-engine.md", "skills/capital-stack-optimizer.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "multi-constraint-sizing", "description": "Loan sized against LTC, LTV, DSCR, and debt yield.", "actionOnFailure": "retry_agent"},
            {"ruleId": "lender-comparison", "description": "At least two lender options compared.", "actionOnFailure": "flag_data_gap"},
            {"ruleId": "maturity-cushion", "description": "Construction loan maturity extends 6+ months past projected stabilization.", "actionOnFailure": "halt_phase"}
          ]
        },
        {
          "agentId": "equity-structurer",
          "file": "agents/development/equity-structurer.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "construction-lender-analyst output", "JV comparables"],
          "outputs": ["JV structure", "promote waterfall", "capital call schedule", "subordinate capital analysis", "term sheet"],
          "critical": true,
          "dependencies": ["construction-lender-analyst"],
          "skillRefs": ["skills/jv-waterfall-architect.md", "skills/mezz-pref-structurer.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "equity-balanced", "description": "GP + LP + subordinate capital must equal total equity requirement.", "actionOnFailure": "halt_phase"},
            {"ruleId": "waterfall-modeled", "description": "Promote waterfall modeled under bear/base/bull scenarios.", "actionOnFailure": "retry_agent"},
            {"ruleId": "protections-documented", "description": "Clawback and LP protections must be specified.", "actionOnFailure": "retry_agent"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "financing-executable", "description": "Construction loan and equity structure are executable at current market terms.", "propagateIfFailed": true},
          {"conditionId": "maturity-adequate", "description": "Loan maturity provides adequate cushion for stabilization.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "financing-unavailable", "description": "No lender willing to finance at required LTC.", "propagateIfFailed": true},
          {"conditionId": "equity-shortfall", "description": "Equity gap cannot be filled from available sources.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["financingUnavailable", "equityShortfall"]
      },
      "dataForDownstreamContract": {
        "constructionLoan": {"type": "object", "required": true, "description": "Loan amount, rate, term, covenants, draw requirements."},
        "equityStructure": {"type": "object", "required": true, "description": "GP/LP split, promote waterfall, capital call schedule."},
        "totalEquity": {"type": "number", "required": true, "description": "Total equity committed."}
      }
    },
    {
      "phaseId": "construction-execution",
      "name": "Construction Execution",
      "weight": 0.20,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "construction-commander",
          "file": "agents/development/construction-commander.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "GC contract", "construction schedule", "design documents"],
          "outputs": ["RFI log", "submittal tracking", "schedule status", "GMP budget tracking", "quality metrics", "monthly report"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/construction-project-command-center.md"],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {"ruleId": "schedule-tracked", "description": "Critical path activities must have actual dates and variance.", "actionOnFailure": "retry_agent"},
            {"ruleId": "budget-tracked", "description": "All GMP line items must show committed, spent, and projected final.", "actionOnFailure": "retry_agent"},
            {"ruleId": "contingency-monitored", "description": "Contingency burn rate and projected remaining calculated.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "draw-request-analyst",
          "file": "agents/development/draw-request-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["GC pay applications", "lien waivers", "inspection reports", "loan agreement"],
          "outputs": ["draw review", "lender draw package", "retainage tracking", "compliance report"],
          "critical": true,
          "dependencies": ["construction-commander"],
          "skillRefs": ["skills/construction-project-command-center.md", "skills/vendor-invoice-validator.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "aia-verified", "description": "G702/G703 arithmetic verified.", "actionOnFailure": "retry_agent"},
            {"ruleId": "liens-tracked", "description": "All required lien waivers tracked.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "change-order-manager",
          "file": "agents/development/change-order-manager.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["CO proposals", "GMP budget", "GC contract", "construction schedule"],
          "outputs": ["CO evaluation", "budget impact analysis", "contingency tracking", "schedule impact", "approval recommendations"],
          "critical": true,
          "dependencies": ["construction-commander"],
          "skillRefs": ["skills/construction-project-command-center.md", "skills/construction-budget-gc-analyzer.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "co-classified", "description": "Every CO must be classified by type with cost responsibility.", "actionOnFailure": "retry_agent"},
            {"ruleId": "markup-verified", "description": "GC markups verified against contract-allowed rates.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "safety-compliance-monitor",
          "file": "agents/development/safety-compliance-monitor.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["safety reports", "inspection data", "insurance certificates", "OSHA standards"],
          "outputs": ["OSHA compliance status", "incident tracking (TRIR/DART)", "insurance monitoring", "inspection log", "compliance report"],
          "critical": false,
          "dependencies": ["construction-commander"],
          "skillRefs": ["skills/compliance-regulatory-response-kit.md", "skills/insurance-risk-manager.md"],
          "maxTimeoutMinutes": 30,
          "validationRules": [
            {"ruleId": "osha-reviewed", "description": "All applicable OSHA standards reviewed and status documented.", "actionOnFailure": "flag_data_gap"},
            {"ruleId": "insurance-current", "description": "Builder's risk and GC GL verified as active.", "actionOnFailure": "flag_data_gap"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "budget-within-contingency", "description": "Budget-to-actual variance within approved contingency limits.", "propagateIfFailed": true},
          {"conditionId": "schedule-within-tolerance", "description": "Construction completion within 30 days of pro forma date.", "propagateIfFailed": true},
          {"conditionId": "loan-compliant", "description": "Construction loan status is IN_COMPLIANCE.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "contingency-exhausted", "description": "Cost overruns exceed entire contingency reserve.", "propagateIfFailed": true},
          {"conditionId": "schedule-critical-delay", "description": "Schedule delayed more than 90 days.", "propagateIfFailed": true},
          {"conditionId": "gc-default", "description": "GC insolvency, construction loan default, or construction halt.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["gcInsolvency", "constructionLoanDefault", "constructionHalt"]
      },
      "dataForDownstreamContract": {
        "constructionCompletionDate": {"type": "string", "required": true, "description": "Actual or projected completion date."},
        "revisedTotalProjectCost": {"type": "number", "required": true, "description": "Updated TDC including all change orders."},
        "constructionLoanStatus": {"type": "string", "required": true, "description": "IN_COMPLIANCE, COVENANT_WATCH, or DEFAULT."}
      }
    },
    {
      "phaseId": "lease-up-stabilization",
      "name": "Lease-Up / Stabilization",
      "weight": 0.20,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "lease-up-strategist",
          "file": "agents/development/lease-up-strategist.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "market data", "construction completion date"],
          "outputs": ["absorption forecast", "pricing matrix", "concession schedule", "weekly leasing report"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/lease-up-war-room.md", "skills/rent-optimization-planner.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "absorption-modeled", "description": "Monthly absorption forecast with occupancy curve from CO to stabilization.", "actionOnFailure": "retry_agent"},
            {"ruleId": "pricing-set", "description": "All unit types priced with market comp validation.", "actionOnFailure": "retry_agent"}
          ]
        },
        {
          "agentId": "marketing-coordinator",
          "file": "agents/development/marketing-coordinator.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["lease-up-strategist output", "marketing budget"],
          "outputs": ["marketing plan", "channel performance", "funnel diagnostics", "marketing ROI"],
          "critical": true,
          "dependencies": ["lease-up-strategist"],
          "skillRefs": ["skills/leasing-strategy-marketing-planner.md", "skills/leasing-operations-engine.md"],
          "maxTimeoutMinutes": 35,
          "validationRules": [
            {"ruleId": "funnel-tracked", "description": "All funnel stages tracked with conversion rates.", "actionOnFailure": "retry_agent"},
            {"ruleId": "cpl-calculated", "description": "Cost per lease computed for each channel.", "actionOnFailure": "flag_data_gap"}
          ]
        },
        {
          "agentId": "stabilization-tracker",
          "file": "agents/development/stabilization-tracker.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["lease-up-strategist output", "proforma-builder output", "operating data"],
          "outputs": ["occupancy tracking", "NOI performance", "reserve stress tests", "maturity monitoring", "stabilization certification"],
          "critical": true,
          "dependencies": ["lease-up-strategist"],
          "skillRefs": ["skills/lease-up-war-room.md", "skills/property-performance-dashboard.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "occupancy-tracked", "description": "Physical and economic occupancy tracked monthly against pro forma.", "actionOnFailure": "retry_agent"},
            {"ruleId": "reserves-tested", "description": "At least 3 stress scenarios with months-of-coverage calculated.", "actionOnFailure": "retry_agent"},
            {"ruleId": "certification-criteria", "description": "All stabilization criteria defined with threshold and actual.", "actionOnFailure": "halt_phase"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "absorption-on-track", "description": "Actual absorption within 15% of pro forma rate.", "propagateIfFailed": true},
          {"conditionId": "stabilization-path-clear", "description": "Stabilization projected within pro forma window.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "absorption-critical", "description": "Absorption more than 30% below pro forma.", "propagateIfFailed": true},
          {"conditionId": "maturity-at-risk", "description": "Construction loan maturity extension unavailable.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["constructionLoanMaturityExtensionUnavailable"]
      },
      "dataForDownstreamContract": {
        "occupancyAtStabilization": {"type": "number", "required": true, "description": "Projected or actual occupancy at stabilization."},
        "stabilizationDate": {"type": "string", "required": true, "description": "Actual or projected stabilization date."},
        "stabilizedNOI": {"type": "number", "required": true, "description": "Actual or projected stabilized NOI."},
        "revisedYieldOnCost": {"type": "number", "required": true, "description": "Revised YOC based on actual costs and NOI."}
      }
    },
    {
      "phaseId": "permanent-financing",
      "name": "Permanent Financing Conversion",
      "weight": 0.10,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "perm-loan-analyst",
          "file": "agents/development/perm-loan-analyst.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["stabilization-tracker output", "construction-lender-analyst output", "permanent lender programs"],
          "outputs": ["permanent loan sizing", "lender comparison", "conversion timeline", "term sheet", "rate sensitivity"],
          "critical": true,
