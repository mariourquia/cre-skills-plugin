            {"ruleId": "multi-constraint", "description": "LTV, DSCR, and debt yield constraints all evaluated.", "actionOnFailure": "retry_agent"},
            {"ruleId": "gap-analyzed", "description": "Construction loan payoff vs perm proceeds gap quantified.", "actionOnFailure": "halt_phase"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "perm-available", "description": "Permanent financing available at acceptable terms.", "propagateIfFailed": true},
          {"conditionId": "conversion-gap-manageable", "description": "Gap equity (if any) covered by available reserves or equity.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "perm-unavailable", "description": "No permanent lender will finance at stabilized NOI.", "propagateIfFailed": true}
        ],
        "dealbreakers": ["permanentLoanNotAvailable"]
      },
      "dataForDownstreamContract": {
        "permanentLoan": {"type": "object", "required": true, "description": "Permanent loan terms: amount, rate, term, DSCR."},
        "conversionDate": {"type": "string", "required": true, "description": "Actual or projected conversion date."}
      }
    },
    {
      "phaseId": "handoff-to-hold",
      "name": "Handoff to Hold Period",
      "weight": 0.10,
      "orchestratorFile": "orchestrators/development-orchestrator.md",
      "agents": [
        {
          "agentId": "development-to-operations-bridge",
          "file": "agents/development/development-to-operations-bridge.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["construction-commander output", "stabilization-tracker output", "GC contract", "PM agreement"],
          "outputs": ["closeout checklist", "warranty register", "PM transition plan", "project archive", "hold-period handoff"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/post-close-onboarding-transition.md"],
          "maxTimeoutMinutes": 40,
          "validationRules": [
            {"ruleId": "closeout-tracked", "description": "All GC deliverables logged with receipt status.", "actionOnFailure": "retry_agent"},
            {"ruleId": "warranties-registered", "description": "All major systems in warranty register.", "actionOnFailure": "retry_agent"},
            {"ruleId": "handoff-written", "description": "Hold-period handoff.json written with all required fields.", "actionOnFailure": "halt_phase"}
          ]
        },
        {
          "agentId": "final-cost-reconciler",
          "file": "agents/development/final-cost-reconciler.md",
          "model": "claude-sonnet-4-6[1m]",
          "inputs": ["proforma-builder output", "change-order-manager output", "draw-request-analyst output", "perm-loan-analyst output"],
          "outputs": ["TDC reconciliation", "contingency closeout", "final return metrics", "sources/uses reconciliation", "LP cost report"],
          "critical": true,
          "dependencies": [],
          "skillRefs": ["skills/dev-proforma-engine.md", "skills/construction-budget-gc-analyzer.md"],
          "maxTimeoutMinutes": 45,
          "validationRules": [
            {"ruleId": "all-categories-reconciled", "description": "All 5 TDC categories must show budget vs actual.", "actionOnFailure": "retry_agent"},
            {"ruleId": "returns-calculated", "description": "All return metrics calculated from actual costs and NOI.", "actionOnFailure": "retry_agent"},
            {"ruleId": "sources-uses-balanced", "description": "Final sources and uses must balance.", "actionOnFailure": "halt_phase"}
          ]
        }
      ],
      "verdictLogic": {
        "thresholdsRef": "development",
        "passConditions": [
          {"conditionId": "transition-complete", "description": "All construction closeout items received and PM transitioned.", "propagateIfFailed": true},
          {"conditionId": "cost-reconciled", "description": "TDC reconciliation complete with LP report produced.", "propagateIfFailed": true}
        ],
        "failConditions": [
          {"conditionId": "critical-closeout-missing", "description": "CO or as-built drawings missing, blocking property operations.", "propagateIfFailed": false}
        ],
        "dealbreakers": []
      },
      "dataForDownstreamContract": {
        "finalTDC": {"type": "number", "required": true, "description": "Reconciled total development cost."},
        "finalReturnMetrics": {"type": "object", "required": true, "description": "YOC, IRR, EM based on actual costs."},
        "exitPath": {"type": "string", "required": true, "description": "HOLD or SELL determination."},
        "warrantyRegister": {"type": "array", "required": true, "description": "All warranty items with expiration dates."}
      }
    }
  ],
  "terminalVerdicts": {
    "STABILIZED": "All phase gates cleared. Property has achieved economic stabilization and transitioned to operations. Development returns confirmed.",
    "DELAYED": "Project viable but behind schedule. Stabilization delayed beyond pro forma window. Loan maturity may require extension.",
    "DISTRESSED": "Fundamental project distress. Budget overrun exceeds contingency, absorption critically below pro forma, or financing default."
  },
  "crossChainHandoffs": [
    {
      "direction": "inbound",
      "counterpartOrchestrator": "fund-management",
      "triggerCondition": "Fund deploys capital to development deal",
      "dataContract": {
        "fundId": {"type": "string", "required": true, "description": "Originating fund identifier."},
        "investmentPolicy": {"type": "object", "required": true, "description": "Fund leverage policy, return targets, concentration limits."},
        "equityCommitment": {"type": "number", "required": true, "description": "Fund equity commitment to development."}
      }
    },
    {
      "direction": "inbound",
      "counterpartOrchestrator": "investment-strategy",
      "triggerCondition": "Investment strategy identifies development opportunity",
      "dataContract": {
        "dealId": {"type": "string", "required": true, "description": "Deal identifier from strategy pipeline."},
        "targetReturns": {"type": "object", "required": true, "description": "IRR, EM, and YOC targets."},
        "marketThesis": {"type": "string", "required": true, "description": "Investment thesis supporting development."}
      }
    },
    {
      "direction": "outbound",
      "counterpartOrchestrator": "capital-stack",
      "triggerCondition": "Phase 'construction-financing' requires construction loan and permanent loan sizing",
      "dataContract": {
        "totalProjectCost": {"type": "number", "required": true, "description": "TDC for loan sizing.", "sourcePhase": "design-pre-construction"},
        "stabilizedNOI": {"type": "number", "required": true, "description": "Projected stabilized NOI for perm sizing.", "sourcePhase": "design-pre-construction"},
        "drawSchedule": {"type": "array", "required": true, "description": "Monthly draw schedule.", "sourcePhase": "design-pre-construction"}
      }
    },
    {
      "direction": "outbound",
      "counterpartOrchestrator": "hold-period",
      "triggerCondition": "Phase 'handoff-to-hold' completes with exit path HOLD",
      "dataContract": {
        "propertyId": {"type": "string", "required": true, "description": "Property identifier for hold-period monitoring.", "sourcePhase": "handoff-to-hold"},
        "acquisitionCost": {"type": "number", "required": true, "description": "Final TDC as acquisition basis.", "sourcePhase": "handoff-to-hold"},
        "stabilizationDate": {"type": "string", "required": true, "description": "Date of economic stabilization.", "sourcePhase": "lease-up-stabilization"},
        "permanentLoan": {"type": "object", "required": true, "description": "Permanent loan terms.", "sourcePhase": "permanent-financing"}
      }
    },
    {
      "direction": "outbound",
      "counterpartOrchestrator": "fund-management",
      "triggerCondition": "Final cost reconciliation produces LP cost report",
      "dataContract": {
        "finalTDC": {"type": "number", "required": true, "description": "Reconciled development cost.", "sourcePhase": "handoff-to-hold"},
        "developmentIRR": {"type": "number", "required": true, "description": "Realized development IRR.", "sourcePhase": "handoff-to-hold"},
        "promoteEarned": {"type": "number", "required": true, "description": "GP promote earned on development.", "sourcePhase": "handoff-to-hold"}
      }
    }
  ],
  "executionConfig": {
    "concurrency": {
      "maxConcurrentPhases": 1,
      "maxAgentsPerPhase": 4
    },
    "timeouts": {
      "defaultAgentMinutes": 40,
      "defaultPhaseMinutes": 180,
      "pipelineMinutes": 1200
    },
    "retryPolicy": {
      "maxAttempts": 3,
      "backoffStrategy": "exponential",
      "baseDelayMs": 15000
    },
    "pollingIntervalMs": 30000,
    "stalledPollThreshold": 10,
    "logging": {
      "categories": [
        "ACTION", "FINDING", "INFO", "PHASE", "ERROR", "DATA_GAP", "COMPLETE",
        "LAUNCH", "RETRY", "TIMEOUT", "VERDICT", "HANDOFF", "DRAW", "CO",
        "GMP", "STABILIZATION", "RESUME", "CROSS_CHECK"
      ]
    }
  }
}
