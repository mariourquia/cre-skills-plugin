{
  "$schema": "Investment Thresholds - Agents use these for go/no-go decisions",
  "verdict": {
    "PASS": "All primary criteria met, no dealbreakers",
    "FAIL": "Any dealbreaker present OR multiple primary criteria fail",
    "CONDITIONAL": "Marginal on some criteria but no dealbreakers"
  },
  "primaryCriteria": {
    "dscr": { "pass": 1.25, "conditional": 1.0, "fail": 1.0, "description": "Debt Service Coverage Ratio" },
    "capRateSpread": { "pass": 100, "conditional": 0, "fail": 0, "unit": "bps", "description": "Cap rate minus debt rate in basis points" },
    "cashOnCash": { "pass": 0.08, "conditional": 0.05, "fail": 0.05, "description": "Annual cash flow / equity invested" },
    "debtYield": { "pass": 0.09, "conditional": 0.07, "fail": 0.07, "description": "NOI / loan amount" },
    "ltv": { "maxPass": 0.75, "maxConditional": 0.80, "fail": 0.80, "description": "Loan to value ratio" }
  },
  "secondaryCriteria": {
    "occupancy": { "strong": 0.95, "acceptable": 0.90, "concern": 0.85, "distressed": 0.80 },
    "expenseRatio": { "excellent": 0.40, "good": 0.45, "acceptable": 0.50, "concern": 0.55 },
    "rentToMarket": { "upside": 0.90, "atMarket": 1.0, "aboveMarket": 1.05, "overpriced": 1.10 },
    "capRate": { "strong": 0.07, "acceptable": 0.055, "marginal": 0.045, "fail": 0.04 },
    "pricePerUnit": { "description": "Compared to market comps and replacement cost" }
  },
  "dealbreakers": [
    "Active title dispute or lis pendens",
    "Property in bankruptcy estate",
    "Dissolved entity ownership",
    "Active environmental contamination (unquantified)",
    "Demolition order or condemnation",
    "Criminal activity nexus",
    "Fraud in title chain",
    "DSCR below 0.80 without clear value-add thesis",
    "Structural failure requiring demolition",
    "Uninsurable property condition"
  ],
  "riskScore": {
    "lowRisk": { "min": 90, "max": 100, "action": "Proceed with standard DD" },
    "lowMediumRisk": { "min": 75, "max": 89, "action": "Proceed with enhanced DD" },
    "mediumRisk": { "min": 60, "max": 74, "action": "Enhanced DD required, price adjustment likely" },
    "mediumHighRisk": { "min": 40, "max": 59, "action": "Significant concerns, major discount required" },
    "highRisk": { "min": 0, "max": 39, "action": "Not recommended" }
  },
  "strategyThresholds": {
