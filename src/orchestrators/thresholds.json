  "thresholdSelectionProtocol": {
    "description": "Defines how agents select and merge the correct threshold set for a given deal",
    "steps": [
      {
        "step": 1,
        "action": "Read investorType from deal.json",
        "field": "deal.investorType",
        "validValues": ["institutional", "pe", "reit", "familyOffice", "syndicator"]
      },
      {
        "step": 2,
        "action": "Read investmentStrategy from deal.json",
        "field": "deal.investmentStrategy",
        "validValues": ["core", "core-plus", "value-add", "opportunistic"]
      },
      {
        "step": 3,
        "action": "Look up strategyThresholdsByInvestorType[investorType][strategy]",
        "description": "Retrieve the strategy-level threshold overrides for the resolved investor type. If the strategy key is not present within the investor type node, proceed to step 4."
      },
      {
        "step": 4,
        "action": "If strategy not in allowedStrategies -> EXCLUDED",
        "description": "If deal.investmentStrategy is not listed in strategyThresholdsByInvestorType[investorType].allowedStrategies, the deal is immediately excluded from further evaluation. No scoring is performed."
      },
      {
        "step": 5,
        "action": "Merge investor overrides with base thresholds",
        "description": "Start with base primaryCriteria and secondaryCriteria. Overlay primaryCriteriaByInvestorType[investorType] values, then overlay strategyThresholdsByInvestorType[investorType][strategy] values. Investor-type fields take precedence over base fields. Strategy-level fields take precedence over investor-type fields.",
        "mergeOrder": ["primaryCriteria (base)", "primaryCriteriaByInvestorType[investorType]", "strategyThresholdsByInvestorType[investorType][strategy]"]
      },
      {
        "step": 6,
        "action": "Apply merged thresholds to all downstream agents",
        "description": "Pass the merged threshold object to every agent in the pipeline (underwriting, financing, due diligence, legal, closing). Agents must not reference the base threshold sections directly -- they must use the merged object provided by the orchestrator."
      }
    ],
    "notes": [
      "investorType and investmentStrategy are required fields in deal.json. Missing fields are a fatal validation error.",
      "dealbreakersByInvestorType[investorType] is appended to (not replaced by) the base dealbreakers array.",
      "thresholdSelectionProtocol is executed once at orchestration start and the merged result is cached for the session.",
      "If investorType is not recognized, fall back to base thresholds and log a warning."
    ]
  }
}
