{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "monthly-actuals.schema.json",
  "title": "Monthly Actual Financials",
  "description": "Monthly actual financial data collected from PM platforms (Yardi/AppFolio/RealPage), normalized to standard chart of accounts",
  "type": "object",
  "required": [
    "propertyId",
    "period",
    "revenue",
    "expenses",
    "noi",
    "belowTheLine",
    "netCashFlow",
    "dataSource",
    "extractedAt",
    "dataQuality"
  ],
  "properties": {
    "propertyId": {
      "type": "string",
      "pattern": "^PROP-[A-Z0-9-]+$",
      "description": "Unique property identifier"
    },
    "period": {
      "type": "string",
      "pattern": "^\\d{4}-(0[1-9]|1[0-2])$",
      "description": "Reporting period in YYYY-MM format"
    },
    "revenue": {
      "type": "object",
      "required": [
        "grossPotentialRent",
        "vacancyLoss",
        "concessions",
        "badDebt",
        "otherIncome",
        "effectiveGrossIncome"
      ],
      "properties": {
        "grossPotentialRent": {
          "type": "number",
          "minimum": 0,
          "description": "Actual gross potential rent for the period"
        },
        "vacancyLoss": {
          "type": "number",
          "description": "Actual vacancy loss for the period"
        },
        "concessions": {
          "type": "number",
          "description": "Actual concessions granted in the period"
        },
        "badDebt": {
          "type": "number",
          "description": "Actual bad debt / write-offs for the period"
        },
        "otherIncome": {
          "type": "object",
          "required": ["laundry", "parking", "petRent", "rubs", "lateFees", "applicationFees", "totalOtherIncome"],
          "properties": {
            "laundry": { "type": "number" },
            "parking": { "type": "number" },
            "petRent": { "type": "number" },
            "rubs": { "type": "number" },
            "lateFees": { "type": "number" },
            "applicationFees": { "type": "number" },
            "totalOtherIncome": { "type": "number" }
          }
        },
        "effectiveGrossIncome": {
          "type": "number",
          "description": "Actual EGI = GPR - vacancyLoss - concessions - badDebt + totalOtherIncome"
        }
      }
    },
    "expenses": {
      "type": "object",
      "required": [
        "realEstateTaxes",
        "insurance",
        "utilities",
        "repairsAndMaintenance",
        "contractServices",
        "payroll",
        "managementFee",
        "generalAndAdmin",
        "marketing",
        "professionalFees",
        "totalOperatingExpenses"
      ],
      "properties": {
        "realEstateTaxes": { "type": "number" },
        "insurance": { "type": "number" },
        "utilities": { "type": "number" },
        "repairsAndMaintenance": { "type": "number" },
        "contractServices": { "type": "number" },
        "payroll": { "type": "number" },
        "managementFee": { "type": "number" },
        "generalAndAdmin": { "type": "number" },
        "marketing": { "type": "number" },
        "professionalFees": { "type": "number" },
        "totalOperatingExpenses": {
          "type": "number",
          "description": "Sum of all expense categories"
        }
      }
    },
    "noi": {
      "type": "number",
      "description": "Actual NOI = EGI - totalOperatingExpenses"
    },
    "belowTheLine": {
      "type": "object",
      "required": ["debtService", "capitalReserves", "tenantImprovements", "leasingCommissions"],
      "properties": {
        "debtService": { "type": "number" },
        "capitalReserves": { "type": "number" },
        "tenantImprovements": { "type": "number" },
        "leasingCommissions": { "type": "number" }
      }
    },
    "netCashFlow": {
      "type": "number",
      "description": "Actual NCF = NOI - debt service - capex reserves - TI - LC"
    },
    "dataSource": {
      "type": "string",
      "enum": ["yardi", "appfolio", "realpage"],
      "description": "PM platform the data was extracted from"
    },
    "extractedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp when data was pulled from the PM platform"
    },
    "dataQuality": {
      "type": "object",
      "required": ["completeness"],
      "properties": {
        "completeness": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of expected fields that are populated (1.0 = all fields present)"
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["field", "severity", "description"],
            "properties": {
              "field": {
                "type": "string",
                "description": "Path to the missing or suspect field"
              },
              "severity": {
                "type": "string",
                "enum": ["CRITICAL", "WARNING", "INFO"],
                "description": "Impact of the gap on downstream analysis"
              },
              "description": {
                "type": "string",
                "description": "Human-readable explanation of the gap"
              }
            }
          },
          "description": "List of data quality gaps identified during extraction"
        },
        "accountMappingOverrides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platformAccountCode": { "type": "string" },
              "platformAccountName": { "type": "string" },
              "canonicalCategory": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "manualOverride": { "type": "boolean" }
            }
          },
          "description": "Account code mappings from platform-specific to canonical; flagged when confidence < 0.9"
        }
      }
    },
    "trailing12": {
      "type": "object",
      "properties": {
        "revenue": { "type": "number" },
        "expenses": { "type": "number" },
        "noi": { "type": "number" },
        "noiPerUnit": { "type": "number" },
        "expenseRatio": { "type": "number" }
      },
      "description": "Trailing 12-month figures updated after each monthly collection"
    }
  }
}
