{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phases/lp-terms-data.schema.json",
  "title": "LP Intelligence Phase 2 -- Fund Terms Analysis Downstream Data",
  "description": "Shape of the dataForDownstream object written to the master checkpoint by the fund terms analysis phase. Covers LPA terms comparison, waterfall modeling, and negotiation recommendations.",
  "type": "object",
  "required": [
    "termsComparison",
    "waterfallAnalysis",
    "termsScore"
  ],
  "properties": {
    "termsComparison": {
      "type": "object",
      "description": "Provision-by-provision LPA terms comparison to market benchmarks.",
      "required": ["economicTerms", "governanceTerms"],
      "properties": {
        "economicTerms": {
          "type": "object",
          "properties": {
            "managementFee": {
              "type": "object",
              "properties": {
                "gpRate": { "type": "number" },
                "marketMedian": { "type": "number" },
                "classification": { "type": "string" },
                "financialImpactBps": { "type": "number" }
              }
            },
            "carriedInterest": {
              "type": "object",
              "properties": {
                "gpRate": { "type": "number" },
                "marketMedian": { "type": "number" },
                "preferredReturn": { "type": "number" },
                "catchUpStructure": { "type": "string" },
                "waterfallType": { "type": "string" },
                "clawbackPresent": { "type": "boolean" },
                "classification": { "type": "string" }
              }
            },
            "gpCoInvestment": {
              "type": "object",
              "properties": {
                "amount": { "type": "number" },
                "asPercentOfFund": { "type": "number" },
                "form": { "type": "string", "enum": ["cash", "fee-waiver", "mixed"] },
                "classification": { "type": "string" }
              }
            },
            "feeOffsets": {
              "type": "object",
              "properties": {
                "transactionFeeOffsetPct": { "type": "number" },
                "monitoringFeeOffsetPct": { "type": "number" },
                "classification": { "type": "string" }
              }
            },
            "organizationalExpenseCap": {
              "type": "object",
              "properties": {
                "capAmount": { "type": ["number", "null"] },
                "capAsPctOfCommitted": { "type": ["number", "null"] },
                "uncapped": { "type": "boolean" },
                "classification": { "type": "string" }
              }
            }
          }
        },
        "governanceTerms": {
          "type": "object",
          "properties": {
            "keyManProvision": {
              "type": "object",
              "properties": {
                "namedKeyPersons": { "type": "integer" },
                "triggerCondition": { "type": "string" },
                "consequence": { "type": "string" },
                "classification": { "type": "string" }
              }
            },
            "noFaultRemoval": {
              "type": "object",
              "properties": {
                "threshold": { "type": "number", "description": "Percentage of interests required" },
                "classification": { "type": "string" }
              }
            },
            "lpacComposition": {
              "type": "object",
              "properties": {
                "size": { "type": "integer" },
                "selectionMethod": { "type": "string" },
                "approvalRights": { "type": "array", "items": { "type": "string" } },
                "classification": { "type": "string" }
              }
            },
            "lpConsentRights": {
              "type": "object",
              "properties": {
                "fundTermExtension": { "type": "boolean" },
                "investmentPeriodExtension": { "type": "boolean" },
                "changeOfControl": { "type": "boolean" },
                "relatedPartyTransactions": { "type": "boolean" },
                "classification": { "type": "string" }
              }
            },
            "reportingRequirements": {
              "type": "object",
              "properties": {
                "frequency": { "type": "string" },
                "ilpaCompliant": { "type": "boolean" },
                "auditStandard": { "type": "string" },
                "classification": { "type": "string" }
              }
            },
            "investmentRestrictions": {
              "type": "object",
              "properties": {
                "singleAssetLimit": { "type": ["number", "null"] },
                "leverageLimit": { "type": ["number", "null"] },
                "geographicRestrictions": { "type": "boolean" },
                "classification": { "type": "string" }
              }
            },
            "fundTermAndExtensions": {
              "type": "object",
              "properties": {
                "initialTermYears": { "type": "integer" },
                "extensionOptions": { "type": "string" },
                "extensionApproval": { "type": "string" },
                "classification": { "type": "string" }
              }
            }
          }
        },
        "missingProvisions": { "type": "array", "items": { "type": "string" } },
        "negotiationPriorityList": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rank": { "type": "integer" },
              "provision": { "type": "string" },
              "currentTerm": { "type": "string" },
              "targetTerm": { "type": "string" },
              "financialImpact": { "type": "string" },
              "negotiability": { "type": "string", "enum": ["high", "moderate", "low"] }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "waterfallAnalysis": {
      "type": "object",
      "description": "Distribution waterfall scenario modeling.",
      "required": ["scenarios", "carryBreakpoints"],
      "properties": {
        "waterfallType": { "type": "string", "enum": ["european", "american", "hybrid"] },
        "preferredReturn": { "type": "number" },
        "carryRate": { "type": "number" },
        "catchUpStructure": { "type": "string" },
        "scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenarioName", "grossIRR", "lpNetIRR", "totalGPCarry"],
            "properties": {
              "scenarioName": { "type": "string" },
              "grossIRR": { "type": "number" },
              "lpNetIRR": { "type": "number" },
              "totalLPDistributions": { "type": "number" },
              "totalGPCarry": { "type": "number" },
              "gpCarryAsPctOfProfits": { "type": "number" },
              "effectiveLPShare": { "type": "number" }
            }
          }
        },
        "europeanVsAmericanComparison": {
          "type": ["object", "null"],
          "properties": {
            "europeanGPCarry": { "type": "number" },
            "americanGPCarry": { "type": "number" },
            "lpIRRDeltaBps": { "type": "number" },
            "clawbackExposure": { "type": "number" }
          }
        },
        "catchUpSensitivity": {
          "type": ["object", "null"],
          "properties": {
            "noCatchUpLPIRR": { "type": "number" },
            "fiftyFiftyCatchUpLPIRR": { "type": "number" },
            "fullCatchUpLPIRR": { "type": "number" },
            "deltaNoVsFullBps": { "type": "number" }
          }
        },
        "carryBreakpoints": {
          "type": "object",
          "properties": {
            "grossIRRCarryKicksIn": { "type": "number" },
            "grossIRRCarryExceeds20PctProfits": { "type": "number" },
            "grossIRRCarryExceeds30PctProfits": { "type": "number" }
          }
        },
        "gpEconomicsTable": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "grossIRR": { "type": "number" },
              "managementFee": { "type": "number" },
              "carry": { "type": "number" },
              "totalGPEconomics": { "type": "number" },
              "gpAsPctOfGross": { "type": "number" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "termsScore": {
      "type": "object",
      "description": "Consolidated terms quality assessment.",
      "required": ["economicScore", "governanceScore", "constraintScore", "transparencyScore", "weightedScore"],
      "properties": {
        "economicScore": { "type": "number", "minimum": 1, "maximum": 5 },
        "governanceScore": { "type": "number", "minimum": 1, "maximum": 5 },
        "constraintScore": { "type": "number", "minimum": 1, "maximum": 5 },
        "transparencyScore": { "type": "number", "minimum": 1, "maximum": 5 },
        "weightedScore": { "type": "number", "minimum": 1, "maximum": 5 },
        "classification": { "type": "string", "enum": ["LP-Favorable", "At Market", "GP-Favorable", "Unacceptable"] },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  },
  "additionalProperties": true
}
