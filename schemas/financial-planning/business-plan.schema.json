{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "business-plan.schema.json",
  "title": "Multi-Year Business Plan",
  "description": "Multi-year business plan covering hold-period, annual, or fund deployment planning with milestones, exit strategy, capital plan, and leasing plan",
  "type": "object",
  "required": [
    "planType",
    "years",
    "perYear",
    "exitStrategy"
  ],
  "properties": {
    "propertyId": {
      "type": ["string", "null"],
      "description": "Property identifier; null for portfolio-level plans"
    },
    "portfolioId": {
      "type": ["string", "null"],
      "description": "Portfolio identifier; null for property-level plans"
    },
    "planType": {
      "type": "string",
      "enum": ["HOLD_PERIOD", "ANNUAL", "DEPLOYMENT"],
      "description": "HOLD_PERIOD: property-level 5-year. ANNUAL: portfolio-level 1-year operational. DEPLOYMENT: fund capital deployment plan."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "UNDER_REVIEW", "APPROVED", "SUPERSEDED"]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "years": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 1,
      "description": "Array of calendar years covered by the plan"
    },
    "perYear": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["year", "revenue", "expenses", "noi", "capex", "debtService", "netCashFlow"],
        "properties": {
          "year": { "type": "integer" },
          "revenue": {
            "type": "number",
            "description": "Projected total revenue (EGI)"
          },
          "revenueGrowthPct": {
            "type": "number",
            "description": "Year-over-year revenue growth rate"
          },
          "expenses": {
            "type": "number",
            "description": "Projected total operating expenses"
          },
          "expenseGrowthPct": {
            "type": "number",
            "description": "Year-over-year expense growth rate"
          },
          "noi": {
            "type": "number",
            "description": "Projected NOI = revenue - expenses"
          },
          "noiMargin": {
            "type": "number",
            "description": "NOI / revenue"
          },
          "capex": {
            "type": "number",
            "description": "Projected capital expenditures for the year"
          },
          "debtService": {
            "type": "number",
            "description": "Projected annual debt service"
          },
          "netCashFlow": {
            "type": "number",
            "description": "NOI - capex - debtService"
          },
          "value": {
            "type": "number",
            "description": "Implied property value = NOI / assumed cap rate"
          },
          "irr": {
            "type": ["number", "null"],
            "description": "Cumulative IRR through this year (null for year 1)"
          },
          "equity": {
            "type": "number",
            "description": "Remaining equity invested (initial equity - principal paydown + additional investment)"
          },
          "dscr": {
            "type": ["number", "null"],
            "description": "Debt service coverage ratio; null if unlevered"
          },
          "cashOnCash": {
            "type": ["number", "null"],
            "description": "Net cash flow / equity invested"
          }
        }
      }
    },
    "milestones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "description", "status"],
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "description": "Target date for the milestone"
          },
          "description": {
            "type": "string",
            "description": "What the milestone represents"
          },
          "status": {
            "type": "string",
            "enum": ["NOT_STARTED", "IN_PROGRESS", "COMPLETED", "DELAYED", "AT_RISK"],
            "description": "Current status of the milestone"
          },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Other milestones this one depends on"
          },
          "impact": {
            "type": "string",
            "description": "Financial impact if milestone is missed"
          }
        }
      }
    },
    "exitStrategy": {
      "type": "object",
      "required": ["year", "method"],
      "properties": {
        "year": {
          "type": "integer",
          "description": "Planned exit year"
        },
        "method": {
          "type": "string",
          "enum": ["SALE", "REFINANCE", "1031_EXCHANGE", "RECAPITALIZATION", "HOLD"],
          "description": "Planned exit method"
        },
        "projectedPrice": {
          "type": "number",
          "description": "Projected sale price at exit"
        },
        "exitCapRate": {
          "type": "number",
          "description": "Assumed cap rate at exit"
        },
        "projectedIRR": {
          "type": "number",
          "description": "Projected levered IRR at exit"
        },
        "projectedEM": {
          "type": "number",
          "description": "Projected equity multiple at exit"
        },
        "sensitivityGrid": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "exitYear": { "type": "integer" },
              "exitCapRate": { "type": "number" },
              "salePrice": { "type": "number" },
              "irr": { "type": "number" },
              "equityMultiple": { "type": "number" }
            }
          },
          "description": "Exit year x cap rate sensitivity matrix"
        }
      }
    },
    "capitalPlan": {
      "type": "object",
      "properties": {
        "totalCapex": {
          "type": "number",
          "description": "Total capex over the plan period"
        },
        "byYear": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year", "total"],
            "properties": {
              "year": { "type": "integer" },
              "total": { "type": "number" },
              "categories": {
                "type": "object",
                "properties": {
                  "roofing": { "type": "number" },
                  "hvac": { "type": "number" },
                  "plumbing": { "type": "number" },
                  "electrical": { "type": "number" },
                  "flooring": { "type": "number" },
                  "exterior": { "type": "number" },
                  "interiorRenovation": { "type": "number" },
                  "amenities": { "type": "number" },
                  "parking": { "type": "number" },
                  "landscaping": { "type": "number" },
                  "other": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "leasingPlan": {
      "type": "object",
      "properties": {
        "byYear": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year"],
            "properties": {
              "year": { "type": "integer" },
              "expirations": {
                "type": "integer",
                "description": "Number of leases expiring"
              },
              "expiringRevenue": {
                "type": "number",
                "description": "Annual revenue from expiring leases"
              },
              "projectedRenewals": {
                "type": "integer",
                "description": "Expected renewals"
              },
              "renewalRate": {
                "type": "number",
                "description": "Projected renewal rate"
              },
              "projectedNewLeases": {
                "type": "integer",
                "description": "Expected new leases to fill vacancies and turnover"
              },
              "avgRentGrowthOnRenewal": {
                "type": "number",
                "description": "Expected rent increase on renewals"
              },
              "avgMarkToMarketOnNewLease": {
                "type": "number",
                "description": "Expected mark-to-market on new leases"
              },
              "projectedTI": {
                "type": "number",
                "description": "Projected tenant improvement costs"
              },
              "projectedLC": {
                "type": "number",
                "description": "Projected leasing commission costs"
              }
            }
          }
        }
      }
    }
  }
}
