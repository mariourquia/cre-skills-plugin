{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phases/research-submarket-data.schema.json",
  "title": "Research Intelligence Phase 3 -- Submarket Deep Dive Downstream Data",
  "description": "Shape of the dataForDownstream object written to the master checkpoint by the submarket deep dives phase. Covers submarket scorecards, competitive sets, and demographic profiles.",
  "type": "object",
  "required": [
    "submarketScoreCards",
    "competitiveSets"
  ],
  "properties": {
    "submarketScoreCards": {
      "type": "array",
      "description": "Per-submarket scorecards with rent growth, supply/demand, competitive, concession, and pipeline risk dimensions.",
      "items": {
        "type": "object",
        "required": ["msa", "submarket", "rentGrowthScore", "supplyDemandScore", "competitiveScore", "concessionScore", "pipelineRiskScore", "compositeScore", "classification"],
        "properties": {
          "msa": { "type": "string" },
          "submarket": { "type": "string" },
          "submarketType": { "type": "string", "enum": ["URBAN_CORE", "URBAN_INFILL", "INNER_SUBURBAN", "OUTER_SUBURBAN", "INSTITUTIONAL"] },
          "rentGrowthScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "supplyDemandScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "competitiveScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "concessionScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "pipelineRiskScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "compositeScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "classification": { "type": "string", "enum": ["INVEST", "MONITOR", "PASS"] },
          "dataQuality": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
          "rentGrowthT12": { "type": "number" },
          "currentVacancy": { "type": "number", "minimum": 0, "maximum": 1 },
          "absorptionRatio": { "type": "number", "minimum": 0 },
          "pipelinePctOfStock": { "type": "number", "minimum": 0 },
          "concessionRate": { "type": "number", "minimum": 0 }
        }
      }
    },
    "competitiveSets": {
      "type": "array",
      "description": "Property-level competitive set data per submarket.",
      "items": {
        "type": "object",
        "required": ["msa", "submarket", "properties"],
        "properties": {
          "msa": { "type": "string" },
          "submarket": { "type": "string" },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["propertyName", "units", "class"],
              "properties": {
                "propertyName": { "type": "string" },
                "units": { "type": "integer", "minimum": 1 },
                "yearBuilt": { "type": "integer" },
                "class": { "type": "string", "enum": ["A", "B", "C"] },
                "avgRent1BR": { "type": "number" },
                "avgRent2BR": { "type": "number" },
                "occupancy": { "type": "number", "minimum": 0, "maximum": 1 },
                "owner": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "demographicProfiles": {
      "type": "array",
      "description": "Per-MSA demographic profiles with population, income, migration, and renter cohort data.",
      "items": {
        "type": "object",
        "required": ["msa", "compositeScore", "classification"],
        "properties": {
          "msa": { "type": "string" },
          "populationGrowth1Yr": { "type": "number" },
          "populationGrowth5Yr": { "type": "number" },
          "medianHouseholdIncome": { "type": "number" },
          "netMigration": { "type": "number" },
          "migrationTrend": { "type": "string", "enum": ["ACCELERATING", "STABLE", "DECELERATING", "NEGATIVE"] },
          "cohort2534Pct": { "type": "number", "minimum": 0, "maximum": 1 },
          "remoteWorkRate": { "type": "number", "minimum": 0, "maximum": 1 },
          "compositeScore": { "type": "number", "minimum": 0, "maximum": 100 },
          "classification": { "type": "string", "enum": ["STRONG", "MODERATE", "WEAK"] }
        }
      }
    },
    "submarketRankings": {
      "type": "object",
      "description": "Tiered submarket rankings across all target MSAs.",
      "properties": {
        "tier1": { "type": "array", "items": { "type": "string" } },
        "tier2": { "type": "array", "items": { "type": "string" } },
        "tier3": { "type": "array", "items": { "type": "string" } },
        "crossSubmarketThemes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
