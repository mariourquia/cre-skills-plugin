{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phases/disposition-closing-data.schema.json",
  "title": "Disposition Phase 7 -- Closing Execution Downstream Data",
  "description": "Shape of the dataForDownstream object written to the master checkpoint by the disposition closing execution phase. Covers closing checklist, prorations, distribution waterfall, final proceeds, and realized returns.",
  "type": "object",
  "required": [
    "closingChecklist",
    "prorations",
    "distributionWaterfall",
    "finalProceeds",
    "realizedReturns"
  ],
  "properties": {
    "closingChecklist": {
      "type": "object",
      "description": "Complete seller-side closing checklist with all conditions and clearance status.",
      "required": ["totalConditions", "clearedCount", "pendingCount", "blockedCount"],
      "properties": {
        "totalConditions": { "type": "integer", "minimum": 0 },
        "clearedCount": { "type": "integer", "minimum": 0 },
        "pendingCount": { "type": "integer", "minimum": 0 },
        "blockedCount": { "type": "integer", "minimum": 0 },
        "allConditionsCleared": { "type": "boolean", "description": "Whether all closing conditions have been cleared." },
        "conditions": {
          "type": "array",
          "description": "Individual closing conditions.",
          "items": {
            "type": "object",
            "required": ["condition", "status", "responsibleParty"],
            "properties": {
              "condition": { "type": "string" },
              "status": { "type": "string", "enum": ["CLEARED", "PENDING", "BLOCKED", "WAIVED"] },
              "responsibleParty": { "type": "string", "enum": ["SELLER", "BUYER", "LENDER", "TITLE", "ESCROW"] },
              "clearanceDate": { "type": "string", "format": "date" },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "requiredDeliverables": {
          "type": "array",
          "description": "Required closing deliverables and preparation status.",
          "items": {
            "type": "object",
            "required": ["document", "status"],
            "properties": {
              "document": { "type": "string", "description": "Document name (deed, bill of sale, assignment of leases, FIRPTA, owner's affidavit, etc.)." },
              "status": { "type": "string", "enum": ["EXECUTED", "READY_FOR_EXECUTION", "IN_PROGRESS", "NOT_STARTED"] },
              "preparedBy": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "prorations": {
      "type": "object",
      "description": "Prorations calculated as of the closing date.",
      "required": ["closingDate", "totalProrationsCredit", "totalProrationsDebit"],
      "properties": {
        "closingDate": { "type": "string", "format": "date", "description": "ISO 8601 closing date used for proration calculations." },
        "totalProrationsCredit": { "type": "number", "description": "Total proration credits to seller." },
        "totalProrationsDebit": { "type": "number", "description": "Total proration debits to seller." },
        "netProrationsToSeller": { "type": "number", "description": "Net prorations (positive = credit to seller)." },
        "lineItems": {
          "type": "array",
          "description": "Individual proration line items.",
          "items": {
            "type": "object",
            "required": ["item", "annualAmount", "sellerShareDays", "sellerAmount"],
            "properties": {
              "item": { "type": "string", "description": "Proration item (rent, real estate taxes, insurance, utilities, CAM, etc.)." },
              "annualAmount": { "type": "number" },
              "sellerShareDays": { "type": "integer" },
              "buyerShareDays": { "type": "integer" },
              "sellerAmount": { "type": "number" },
              "buyerAmount": { "type": "number" },
              "direction": { "type": "string", "enum": ["CREDIT_TO_SELLER", "DEBIT_TO_SELLER"] }
            },
            "additionalProperties": true
          }
        },
        "prorationsVarianceFromEstimate": {
          "type": "number",
          "description": "Variance between final prorations and preliminary estimates as decimal."
        },
        "postClosingTrueUpRequired": {
          "type": "boolean",
          "description": "Whether post-closing proration true-up is required."
        }
      },
      "additionalProperties": true
    },
    "distributionWaterfall": {
      "type": "object",
      "description": "Full waterfall calculation with tier-by-tier breakdown.",
      "required": ["netDistributableProceeds", "tiers", "totalDistributed", "waterfallBalances"],
      "properties": {
        "netDistributableProceeds": {
          "type": "number",
          "description": "Net proceeds available for distribution after debt payoff, closing costs, and reserves."
        },
        "tiers": {
          "type": "array",
          "description": "Waterfall tiers per JV/fund agreement.",
          "items": {
            "type": "object",
            "required": ["tierNumber", "tierName", "lpShare", "gpShare", "tierAmount"],
            "properties": {
              "tierNumber": { "type": "integer" },
              "tierName": { "type": "string", "description": "Return of capital, preferred return, first promote, second promote, etc." },
              "hurdleRate": { "type": "number", "description": "IRR hurdle for this tier (if applicable)." },
              "lpSplitPct": { "type": "number", "description": "LP percentage split in this tier." },
              "gpSplitPct": { "type": "number", "description": "GP percentage split in this tier." },
              "tierAmount": { "type": "number", "description": "Total amount distributed in this tier." },
              "lpShare": { "type": "number", "description": "LP dollar share in this tier." },
              "gpShare": { "type": "number", "description": "GP dollar share (promote) in this tier." },
              "cumulative": { "type": "boolean", "description": "Whether hurdle is cumulative or incremental." }
            },
            "additionalProperties": true
          }
        },
        "gpPromoteTotal": {
          "type": "number",
          "description": "Total GP promote earned across all tiers."
        },
        "lpDistributions": {
          "type": "array",
          "description": "Per-LP distribution amounts.",
          "items": {
            "type": "object",
            "required": ["lpName", "capitalContribution", "distributionAmount"],
            "properties": {
              "lpName": { "type": "string" },
              "lpId": { "type": "string" },
              "ownershipPct": { "type": "number" },
              "capitalContribution": { "type": "number" },
              "preferredReturnAccrued": { "type": "number" },
              "distributionAmount": { "type": "number" },
              "realizedIRR": { "type": "number" },
              "equityMultiple": { "type": "number" }
            },
            "additionalProperties": true
          }
        },
        "totalDistributed": {
          "type": "number",
          "description": "Sum of all distributions (LP + GP). Must equal netDistributableProceeds."
        },
        "waterfallBalances": {
          "type": "boolean",
          "description": "Whether totalDistributed equals netDistributableProceeds within $1 tolerance."
        }
      },
      "additionalProperties": true
    },
    "finalProceeds": {
      "type": "object",
      "description": "Final net proceeds breakdown.",
      "required": ["grossSalePrice", "debtPayoff", "closingCosts", "brokerCommission", "netToSeller"],
      "properties": {
        "grossSalePrice": { "type": "number", "description": "Gross sale price per PSA." },
        "debtPayoff": { "type": "number", "description": "Total debt payoff including prepayment penalty." },
        "closingCosts": { "type": "number", "description": "Seller-side closing costs." },
        "brokerCommission": { "type": "number", "description": "Broker commission." },
        "transferTax": { "type": "number", "description": "Transfer taxes." },
        "prorations": { "type": "number", "description": "Net prorations (positive = credit to seller)." },
        "retradeCredits": { "type": "number", "description": "Credits given to buyer for retrade concessions." },
        "netToSeller": { "type": "number", "description": "Net proceeds to seller after all deductions." },
        "reserveHoldback": { "type": "number", "description": "Post-closing reserve holdback (if any)." }
      },
      "additionalProperties": true
    },
    "realizedReturns": {
      "type": "object",
      "description": "Realized return metrics for the investment.",
      "required": ["realizedIRR", "equityMultiple", "holdPeriod_years"],
      "properties": {
        "realizedIRR": { "type": "number", "description": "Realized IRR for the investment as decimal." },
        "equityMultiple": { "type": "number", "description": "Realized equity multiple." },
        "holdPeriod_years": { "type": "number", "description": "Actual hold period in years." },
        "totalEquityInvested": { "type": "number" },
        "totalDistributions": { "type": "number" },
        "totalCashFlow": { "type": "number", "description": "Total cash flow during hold period (operating + disposition)." },
        "acquisitionCost": { "type": "number" },
        "valueCreated": { "type": "number", "description": "Gross sale price minus acquisition cost." },
        "irrVsTarget": { "type": "number", "description": "Realized IRR minus target IRR (positive = outperformance)." }
      },
      "additionalProperties": true
    },
    "exchange1031Status": {
      "type": "object",
      "description": "1031 exchange status (if applicable).",
      "properties": {
        "exchangeActive": { "type": "boolean", "description": "Whether a 1031 exchange is being executed." },
        "qualifiedIntermediary": { "type": "string", "description": "QI name." },
        "identificationDeadline": { "type": "string", "format": "date", "description": "45-day identification deadline." },
        "closingDeadline": { "type": "string", "format": "date", "description": "180-day closing deadline." },
        "identifiedProperties": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "address": { "type": "string" },
              "estimatedValue": { "type": "number" },
              "status": { "type": "string", "enum": ["IDENTIFIED", "UNDER_CONTRACT", "CLOSED", "DROPPED"] }
            },
            "additionalProperties": true
          }
        },
        "bootCalculation": { "type": "number", "description": "Taxable boot amount (proceeds not reinvested)." },
        "deferredGain": { "type": "number", "description": "Capital gain deferred through exchange." }
      },
      "additionalProperties": true
    },
    "k1Impact": {
      "type": "object",
      "description": "K-1 impact summary for tax reporting.",
      "properties": {
        "capitalGainAllocations": { "type": "number" },
        "ordinaryIncomeAllocations": { "type": "number" },
        "depreciationRecapture": { "type": "number" },
        "section1231Gain": { "type": "number" },
        "estimatedTaxLiability": { "type": "number" }
      },
      "additionalProperties": true
    },
    "postClosingObligations": {
      "type": "array",
      "description": "Post-closing obligations and deadlines.",
      "items": {
        "type": "object",
        "required": ["obligation", "deadline"],
        "properties": {
          "obligation": { "type": "string" },
          "deadline": { "type": "string", "format": "date" },
          "responsibleParty": { "type": "string" },
          "status": { "type": "string", "enum": ["PENDING", "COMPLETE"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
